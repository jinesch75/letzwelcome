# ─── NextAuth ───
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# ─── OAuth Providers ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
